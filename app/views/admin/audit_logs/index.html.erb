<div class="space-y-6">
  <h1 class="text-2xl font-bold text-slate-800">Registro de auditoría</h1>

  <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Fecha</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Actor</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Acción</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Objetivo</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">IP</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Detalles</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @logs.each do |log| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 text-sm text-slate-600 whitespace-nowrap"><%= l(log.created_at, format: :short) %></td>
            <td class="px-4 py-3 text-sm text-slate-800"><%= log.actor&.name %></td>
            <td class="px-4 py-3">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= audit_action_class(log.action) %>">
                <%= t("admin.audit.actions.#{log.action}", default: log.action.humanize) %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-slate-600">
              <% if log.target_type.present? %>
                <%= log.target_type %> #<%= log.target_id %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-slate-500 font-mono"><%= log.ip_address || "—" %></td>
            <td class="px-4 py-3 text-xs text-slate-500">
              <% if log.metadata.present? && log.metadata.any? %>
                <%= log.metadata.map { |k, v| "#{k}: #{v}" }.join(", ") %>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @logs.empty? %>
      <p class="p-8 text-center text-slate-500">No hay registros de auditoría.</p>
    <% end %>
  </div>

  <%= pagy_nav(@pagy) if @pagy && @pagy.pages > 1 %>

  <%= link_to "← Volver al admin", admin_root_path, class: "text-sm text-slate-600 hover:text-slate-800" %>
</div>
