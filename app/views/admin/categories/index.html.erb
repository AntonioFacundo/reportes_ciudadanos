<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-slate-800">Categorías</h1>
    <%= link_to "Nueva categoría", new_admin_category_path, class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700" %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Nombre</th>
          <% if Current.user&.system_admin? %>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Alcaldía</th>
          <% end %>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">SLA (horas)</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @categories.each do |category| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 text-slate-800"><%= category.name %></td>
            <% if Current.user&.system_admin? %>
              <td class="px-4 py-3 text-slate-600"><%= category.alcaldia&.name %></td>
            <% end %>
            <td class="px-4 py-3 text-slate-600"><%= category.sla_hours || "—" %></td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap items-center justify-end gap-2">
                <%= link_to "Editar", edit_admin_category_path(category), class: "inline-block rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
                <%= button_to "Eliminar", admin_category_path(category), method: :delete, form: { class: "inline-block" }, class: "rounded-lg border border-red-200 bg-white px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50", data: { turbo_confirm: "¿Eliminar esta categoría?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @categories.empty? %>
      <p class="p-8 text-center text-slate-500">No hay categorías. Crea la primera.</p>
    <% end %>
  </div>

  <%= pagy_nav(@pagy, label: "categorías") if @pagy && @pagy.pages > 1 %>

  <%= link_to "← Volver al admin", admin_root_path, class: "text-sm text-slate-600 hover:text-slate-800" %>
</div>
