<div class="mx-auto max-w-lg space-y-6">
  <h1 class="text-2xl font-bold text-slate-800">Editar ciudadano</h1>

  <%= form_with(model: @citizen, url: admin_citizen_path(@citizen), method: :patch, class: "space-y-4 rounded-xl border border-slate-200 bg-white p-6") do |f| %>
    <% if @citizen.errors.any? %>
      <div class="rounded-lg bg-red-50 p-4 text-sm text-red-700">
        <ul class="list-disc list-inside space-y-1">
          <% @citizen.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
      <%= f.email_field :email_address, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500", placeholder: "opcional" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Nueva contraseña</label>
      <%= f.password_field :password, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500", placeholder: "Dejar en blanco para no cambiar" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Confirmar contraseña</label>
      <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" %>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to "Cancelar", admin_citizen_path(@citizen), class: "text-sm text-slate-600 hover:text-slate-800" %>
      <%= f.submit "Guardar cambios", class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
