<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">Ciudadanos</h1>
      <p class="mt-1 text-sm text-slate-500"><%= @total %> ciudadanos registrados</p>
    </div>
  </div>

  <div class="p-4 bg-white rounded-xl border border-slate-200">
    <%= form_tag admin_citizens_path, method: :get, class: "flex flex-wrap items-end gap-3" do %>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Buscar</label>
        <input type="text" name="q" value="<%= params[:q] %>" placeholder="Nombre del ciudadano..."
               class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" />
      </div>
      <div class="min-w-[130px]">
        <label class="block text-xs font-medium text-slate-500 mb-1">Estado</label>
        <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
          <option value="">Todos</option>
          <option value="active" <%= "selected" if params[:status] == "active" %>>Activos</option>
          <option value="inactive" <%= "selected" if params[:status] == "inactive" %>>Inactivos</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition">Filtrar</button>
        <% if params[:q].present? || params[:status].present? %>
          <%= link_to "Limpiar", admin_citizens_path, class: "px-4 py-2 bg-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-300 transition" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Nombre</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Correo</th>
          <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wide text-slate-600">Reportes</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Registro</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Estado</th>
          <% if Current.user&.system_admin? %>
            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Acciones</th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @citizens.each do |citizen| %>
          <tr class="hover:bg-slate-50 <%= 'opacity-60' unless citizen.active? %>">
            <td class="px-4 py-3 text-slate-800 font-medium">
              <%= link_to citizen.name, admin_citizen_path(citizen), class: "hover:text-teal-600 hover:underline" %>
            </td>
            <td class="px-4 py-3 text-slate-600 text-sm"><%= citizen.email_address || "—" %></td>
            <td class="px-4 py-3 text-center">
              <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                <%= @report_counts[citizen.id] || 0 %>
              </span>
            </td>
            <td class="px-4 py-3 text-slate-500 text-sm"><%= citizen.created_at.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3">
              <% if citizen.active? %>
                <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800">Activo</span>
              <% else %>
                <span class="rounded-full bg-slate-200 px-2.5 py-0.5 text-xs font-medium text-slate-600">Inactivo</span>
              <% end %>
            </td>
            <% if Current.user&.system_admin? %>
              <td class="px-4 py-3">
                <div class="flex flex-wrap items-center justify-end gap-2">
                  <%= link_to "Ver", admin_citizen_path(citizen), class: "inline-block rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
                  <%= link_to "Editar", edit_admin_citizen_path(citizen), class: "inline-block rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
                  <% if citizen.active? %>
                    <%= button_to "Desactivar", deactivate_admin_citizen_path(citizen), method: :patch, form: { class: "inline-block" }, class: "rounded-lg border border-red-200 bg-white px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50", data: { turbo_confirm: "¿Desactivar a #{citizen.name}?" } %>
                  <% else %>
                    <%= button_to "Reactivar", reactivate_admin_citizen_path(citizen), method: :patch, form: { class: "inline-block" }, class: "rounded-lg border border-emerald-200 bg-white px-3 py-1.5 text-sm font-medium text-emerald-600 hover:bg-emerald-50", data: { turbo_confirm: "¿Reactivar a #{citizen.name}?" } %>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @citizens.empty? %>
      <p class="p-8 text-center text-slate-500">No se encontraron ciudadanos.</p>
    <% end %>
  </div>

  <%= pagy_nav(@pagy, path_method: :admin_citizens_path) if @pagy && @pagy.pages > 1 %>

  <%= link_to "← Volver al admin", admin_root_path, class: "text-sm text-slate-600 hover:text-slate-800" %>
</div>
