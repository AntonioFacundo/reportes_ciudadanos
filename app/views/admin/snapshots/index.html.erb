<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">Historial de reportes</h1>
      <p class="mt-1 text-sm text-slate-500">Snapshots diarios del estado de los reportes.</p>
    </div>
    <%= button_to "Capturar snapshot ahora", capture_admin_snapshots_path, method: :post, class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700", data: { turbo_confirm: "¿Capturar snapshot del estado actual?" } %>
  </div>

  <% if Current.user&.system_admin? %>
    <div class="p-4 bg-white rounded-xl border border-slate-200">
      <%= form_tag admin_snapshots_path, method: :get, class: "flex flex-wrap items-end gap-3", data: { alcaldias_by_state: "", selected_alcaldia_id: params[:alcaldia_id] } do %>
        <div class="flex-1 min-w-[180px]">
          <label class="block text-xs font-medium text-slate-500 mb-1">Estado</label>
          <select name="state_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
            <option value="">Todos</option>
            <% (@states || []).each do |s| %>
              <option value="<%= s.id %>" <%= "selected" if params[:state_id].to_s == s.id.to_s %>><%= s.name %></option>
            <% end %>
          </select>
        </div>
        <div class="flex-1 min-w-[200px]">
          <label class="block text-xs font-medium text-slate-500 mb-1">Alcaldía</label>
          <select name="alcaldia_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
            <option value="" disabled selected>Selecciona un estado primero</option>
          </select>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition">Filtrar</button>
          <% if params[:state_id].present? || params[:alcaldia_id].present? %>
            <%= link_to "Limpiar", admin_snapshots_path, class: "px-4 py-2 bg-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-300 transition" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @chart_data[:labels].any? %>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="text-lg font-semibold text-slate-800 mb-4">Evolución</h2>
      <div style="position: relative; height: 300px;">
        <canvas id="snapshot-chart"></canvas>
      </div>
    </div>

    <script>
      (function() {
        var data = <%= raw @chart_data.to_json %>;
        function init() {
          var el = document.getElementById("snapshot-chart");
          if (!el || typeof Chart === "undefined") return;
          var existing = Chart.getChart(el);
          if (existing) existing.destroy();
          new Chart(el, {
            type: "line",
            data: {
              labels: data.labels,
              datasets: [
                { label: "Total", data: data.total, borderColor: "#334155", backgroundColor: "rgba(51,65,85,0.1)", tension: 0.3, fill: false },
                { label: "Pendientes", data: data.pending, borderColor: "#f59e0b", backgroundColor: "rgba(245,158,11,0.1)", tension: 0.3, fill: false },
                { label: "Asignados", data: data.assigned, borderColor: "#3b82f6", backgroundColor: "rgba(59,130,246,0.1)", tension: 0.3, fill: false },
                { label: "Resueltos", data: data.resolved, borderColor: "#0d9488", backgroundColor: "rgba(13,148,136,0.1)", tension: 0.3, fill: false },
                { label: "Atrasados", data: data.overdue, borderColor: "#ef4444", backgroundColor: "rgba(239,68,68,0.1)", tension: 0.3, fill: false }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              interaction: { mode: "index", intersect: false },
              plugins: { legend: { position: "bottom" } },
              scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
          });
        }
        document.addEventListener("turbo:load", init);
        init();
      })();
    </script>
  <% end %>

  <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Fecha</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600">Alcaldía</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Total</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Pend.</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Asign.</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Resuel.</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Atras.</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Reabiertos</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Prom. resolución</th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600">Prom. respuesta</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @snapshots.each do |snap| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 text-sm text-slate-800 font-medium whitespace-nowrap"><%= snap.snapshot_date.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3 text-sm text-slate-600"><%= snap.alcaldia.name %></td>
            <td class="px-4 py-3 text-sm text-slate-800 text-right font-semibold"><%= snap.total_reports %></td>
            <td class="px-4 py-3 text-sm text-amber-600 text-right"><%= snap.pending_count %></td>
            <td class="px-4 py-3 text-sm text-blue-600 text-right"><%= snap.assigned_count %></td>
            <td class="px-4 py-3 text-sm text-teal-600 text-right"><%= snap.resolved_count %></td>
            <td class="px-4 py-3 text-sm text-red-600 text-right"><%= snap.overdue_count %></td>
            <td class="px-4 py-3 text-sm text-slate-600 text-right"><%= snap.reopened_count %></td>
            <td class="px-4 py-3 text-sm text-slate-600 text-right">
              <% if snap.avg_resolution_hours %>
                <%= "%.1f" % snap.avg_resolution_hours %>h
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-slate-600 text-right">
              <% if snap.avg_response_hours %>
                <%= "%.1f" % snap.avg_response_hours %>h
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @snapshots.empty? %>
      <div class="p-8 text-center text-slate-500">
        <p>No hay snapshots aún.</p>
        <p class="mt-1 text-sm text-slate-400">Se capturan automáticamente cada día a las 23:55, o puedes capturar uno manualmente.</p>
      </div>
    <% end %>
  </div>

  <%= pagy_nav(@pagy) if @pagy && @pagy.pages > 1 %>

  <%= link_to "← Volver al admin", admin_root_path, class: "text-sm text-slate-600 hover:text-slate-800" %>
</div>
