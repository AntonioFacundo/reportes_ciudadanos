<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-slate-800"><%= I18n.t("admin.states.title") %></h1>
    <%= link_to I18n.t("admin.states.new"), new_admin_state_path, class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700" %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600"><%= I18n.t("admin.states.columns.code") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600"><%= I18n.t("admin.states.columns.name") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-slate-600"><%= I18n.t("admin.states.columns.alcaldias") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-slate-600"><%= I18n.t("admin.states.columns.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @states.each do |state| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 font-mono text-sm text-slate-600"><%= state.code %></td>
            <td class="px-4 py-3 font-medium text-slate-800"><%= state.name %></td>
            <td class="px-4 py-3 text-slate-600"><%= state.respond_to?(:alcaldias_count) ? state.alcaldias_count : state.alcaldias.count %></td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap items-center justify-end gap-2">
                <%= link_to I18n.t("admin.states.actions.edit"), edit_admin_state_path(state), class: "inline-block rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
                <%= button_to I18n.t("admin.states.actions.delete"), admin_state_path(state), method: :delete, form: { class: "inline-block" }, class: "rounded-lg border border-red-200 bg-white px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50", data: { turbo_confirm: I18n.t("admin.states.confirm_delete", name: state.name) } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @states.empty? %>
      <p class="p-8 text-center text-slate-500"><%= I18n.t("admin.states.empty") %></p>
    <% end %>
  </div>

  <%= pagy_nav(@pagy, label: I18n.t("admin.states.title").downcase) if @pagy && @pagy.pages > 1 %>

  <%= link_to "← #{I18n.t('admin.states.back_to_admin')}", admin_root_path, class: "text-sm text-slate-600 hover:text-slate-800" %>
</div>
