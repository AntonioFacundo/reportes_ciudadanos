<div class="max-w-lg">
  <h1 class="text-2xl font-bold text-slate-800">Editar usuario</h1>

  <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "mt-6 space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded-lg bg-red-50 p-4 text-sm text-red-800">
        <%= @user.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Nombre (usuario)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" %>
    </div>

    <div>
      <%= f.label :email_address, "Email (opcional)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email_address, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" %>
    </div>

    <div>
      <%= f.label :role, "Rol", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :role,
          options_for_select(admin_role_options, @user.role),
          {},
          class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" %>
    </div>

    <% if @alcaldias && Current.user&.system_admin? %>
      <div>
        <%= f.label :alcaldia_id, "Alcaldía", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :alcaldia_id,
            options_from_collection_for_select(@alcaldias, :id, :name, @user.alcaldia_id),
            { include_blank: "" },
            { data: { searchable: true, placeholder: "Buscar alcaldía..." }, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" } %>
      </div>
    <% end %>

    <div>
      <%= f.label :manager_id, "Superior (manager)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :manager_id,
          options_from_collection_for_select(@managers, :id, :name, @user.manager_id),
          { include_blank: "" },
          { data: { searchable: true, placeholder: "Buscar superior..." }, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" } %>
    </div>

    <div>
      <%= f.label :password, "Nueva contraseña (dejar en blanco para no cambiar)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmar contraseña", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full rounded-lg border-slate-300 shadow-sm focus:border-teal-500 focus:ring-teal-500" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Guardar cambios", class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700" %>
      <%= link_to "Cancelar", admin_users_path, class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>

  <%= link_to "← Volver a usuarios", admin_users_path, class: "mt-6 inline-block text-sm text-slate-600 hover:text-slate-800" %>
</div>
