<%= turbo_stream_from :reports %>
<div>
  <h1 class="text-2xl font-bold text-slate-800"><%= t("reports.index.title") %></h1>

  <% current_filter = params[:filter].presence || "all" %>
  <div class="mt-4 flex flex-wrap gap-2">
    <%= link_to t("reports.filters.all"), reports_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'all' || current_filter.blank? ? 'bg-teal-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
    <%= link_to t("reports.filters.pending"), reports_path(filter: "pending"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'pending' ? 'bg-teal-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
    <%= link_to t("reports.filters.assigned"), reports_path(filter: "assigned"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'assigned' ? 'bg-teal-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
    <%= link_to t("reports.filters.resolved"), reports_path(filter: "resolved"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'resolved' ? 'bg-teal-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
    <%= link_to t("reports.filters.rejected"), reports_path(filter: "rejected"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'rejected' ? 'bg-red-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
    <%= link_to t("reports.filters.reopened"), reports_path(filter: "reopened"), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{current_filter == 'reopened' ? 'bg-teal-600 text-white' : 'bg-slate-200 text-slate-700 hover:bg-slate-300'}" %>
  </div>

  <!-- Search filters -->
  <div class="mt-4 p-4 bg-white rounded-xl border border-slate-200">
    <%= form_tag reports_path, method: :get, class: "space-y-3" do %>
      <%= hidden_field_tag :filter, params[:filter] if params[:filter].present? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <div>
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="<%= t('reports.search.placeholder') %>"
                 class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
        </div>
        <div>
          <select name="category_id" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500">
            <option value=""><%= t("reports.search.all_categories") %></option>
            <% @categories.each do |cat| %>
              <option value="<%= cat.id %>" <%= "selected" if params[:category_id].to_s == cat.id.to_s %>><%= cat.name %></option>
            <% end %>
          </select>
        </div>
        <div>
          <select name="status" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500">
            <option value=""><%= t("reports.search.all_statuses") %></option>
            <% Report::STATUSES.each do |s| %>
              <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= t("status.#{s}") %></option>
            <% end %>
            <option value="rejected" <%= "selected" if params[:status] == "rejected" %>><%= t("status.rejected") %></option>
            <option value="reopened" <%= "selected" if params[:status] == "reopened" %>><%= t("status.reopened") %></option>
          </select>
        </div>
        <div class="flex items-center gap-1.5">
          <input type="date" name="date_from" value="<%= params[:date_from] %>"
                 class="date-compact border border-slate-300 rounded-md focus:outline-none focus:ring-1 focus:ring-teal-500 focus:border-teal-500"
                 title="<%= t('reports.search.date_from') %>" />
          <span class="text-slate-400 text-xs">–</span>
          <input type="date" name="date_to" value="<%= params[:date_to] %>"
                 class="date-compact border border-slate-300 rounded-md focus:outline-none focus:ring-1 focus:ring-teal-500 focus:border-teal-500"
                 title="<%= t('reports.search.date_to') %>" />
        </div>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition">
          <%= t("reports.search.submit") %>
        </button>
        <% if params[:q].present? || params[:category_id].present? || params[:status].present? || params[:date_from].present? || params[:date_to].present? %>
          <%= link_to t("reports.search.clear"), reports_path(filter: params[:filter].presence), class: "px-4 py-2 bg-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-300 transition" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% reports = @reports || [] %>
  <% if reports.any? %>
    <div class="mt-6 space-y-4">
      <% reports.each do |report| %>
        <%= link_to report_path(report), class: "block p-4 rounded-xl bg-white border border-slate-200 hover:border-teal-300 hover:shadow-md transition", data: { turbo_prefetch: false } do %>
          <div class="flex justify-between items-start">
            <div class="flex-1 min-w-0">
              <p class="font-medium text-slate-800 truncate"><%= report.description.truncate(60) %></p>
              <p class="text-sm text-slate-500 mt-1"><%= report.category&.name %> · <%= l(report.created_at, format: :short) %></p>
            </div>
            <span class="ml-3 flex items-center gap-1">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_badge_class(report_display_status(report)) %>">
                <%= t("status.#{report_display_status(report)}", default: report_display_status(report)) %>
              </span>
              <%= sla_badge(report) %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
    <%= pagy_nav(@pagy, path_method: :reports_path, label: "reportes") if @pagy && @pagy.pages > 1 %>
  <% else %>
    <div class="mt-8 p-8 rounded-xl bg-slate-50 border border-slate-200 text-center">
      <p class="text-slate-600"><%= t("reports.index.empty") %></p>
      <%= link_to t("reports.index.create_first"), new_report_path, class: "mt-4 inline-block py-2 px-4 rounded-lg bg-teal-600 text-white font-medium hover:bg-teal-700" %>
    </div>
  <% end %>
</div>
