<%= turbo_stream_from @report if @report %>
<div class="rounded-xl bg-white border border-slate-200 p-6" id="report_<%= @report&.id %>">
  <% if @report %>
    <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
      <span class="flex items-center gap-2">
        <span class="px-3 py-1 rounded-full text-sm font-medium <%= status_badge_class(report_display_status(@report)) %>">
          <%= t("status.#{report_display_status(@report)}", default: report_display_status(@report)) %>
        </span>
        <%= sla_badge(@report) %>
      </span>
      <span class="text-sm text-slate-500"><%= l(@report.created_at, format: :long) %></span>
    </div>

    <% if Current.user&.government? && @report.pending? %>
      <div class="mb-4">
        <%= button_to "Marcar como leído", mark_read_report_path(@report), method: :patch, class: "px-3 py-2 rounded-lg bg-teal-600 text-white text-sm font-medium hover:bg-teal-700" %>
      </div>
    <% end %>

    <% if Current.user&.government? && @assignable.present? && (@report.pending? || @report.read?) %>
      <div class="mb-4 p-4 rounded-lg bg-slate-50 border border-slate-200">
        <p class="text-sm font-medium text-slate-700 mb-2">Asignar a</p>
        <%= form_with url: assign_report_path(@report), method: :patch, local: true, id: "assign-report-form", class: "space-y-3" do |f| %>
          <div>
            <%= f.select :assignee_id,
                options_from_collection_for_select(@assignable, :id, :name),
                { include_blank: "" },
                { data: { searchable: true, placeholder: "Buscar funcionario..." }, class: "w-full rounded-lg border-slate-300 mb-2" } %>
            <%= f.text_area :assignment_note, rows: 2, placeholder: "Nota para el asignado (opcional)...", class: "w-full rounded-lg border-slate-300 text-sm mb-2" %>
            <%= f.submit "Asignar", class: "px-4 py-2 rounded-lg bg-teal-600 text-white font-medium hover:bg-teal-700 border-2 border-teal-700" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if Current.user&.government? && @report.assigned? && (Current.user.id == @report.assignee_id || Current.user.mayor? || Current.user.system_admin?) %>
      <div class="mb-4 p-4 rounded-lg bg-emerald-50 border border-emerald-200">
        <p class="text-sm font-medium text-slate-700 mb-2">Resolver reporte</p>
        <%= form_with url: resolve_report_path(@report), method: :patch, local: true, multipart: true, class: "space-y-4" do |f| %>
          <%= text_area_tag "resolution_note", nil, rows: 3, placeholder: "Nota de resolución o adjunta fotos...", class: "w-full rounded-lg border-slate-300" %>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald-100 text-emerald-800 hover:bg-emerald-200 cursor-pointer text-sm font-medium" onclick="this.querySelector('input[type=file]').click()">
            <span>Elegir fotos</span>
            <%= file_field_tag "resolution_photos[]", multiple: true, accept: "image/*", style: "position:fixed;left:-9999px;width:1px;height:1px;opacity:0", onchange: "this.closest('[onclick]').querySelector('.file-count').textContent = this.files.length ? this.files.length + ' archivo(s) elegido(s)' : 'Ningún archivo elegido'" %>
            <span class="file-count text-slate-500 font-normal">Ningún archivo elegido</span>
          </div>
          <div class="pt-2">
            <%= f.submit "Guardar resolución", class: "w-full py-3 px-4 rounded-lg bg-teal-600 text-white font-semibold hover:bg-teal-700 text-base cursor-pointer border-2 border-teal-700 shadow-md" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="space-y-4">
      <% if @report.reporter_rejection_note.present? && (Current.user&.government? || Current.user&.id == @report.reporter_id) %>
        <div class="p-3 rounded-lg bg-red-50 border border-red-200">
          <p class="text-xs font-medium text-red-800 uppercase tracking-wide">
            <%= Current.user&.id == @report.reporter_id ? "Tu réplica" : "Réplica del ciudadano" %>
          </p>
          <p class="mt-1 text-sm text-slate-800 whitespace-pre-wrap"><%= @report.reporter_rejection_note %></p>
        </div>
      <% end %>

      <% if @report.assignee.present? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Asignado a</p>
          <p class="mt-1 text-slate-800"><%= @report.assignee.name %></p>
          <% if @report.assignment_note.present? && (Current.user&.id == @report.assignee_id || Current.user&.mayor? || Current.user&.system_admin?) %>
            <div class="mt-2 p-3 rounded-lg bg-amber-50 border border-amber-200">
              <p class="text-xs font-medium text-amber-800">Nota del alcalde</p>
              <p class="mt-1 text-sm text-slate-800 whitespace-pre-wrap"><%= @report.assignment_note %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("reports.show.category") %></p>
        <p class="mt-1 text-slate-800"><%= @report.category&.name %></p>
      </div>

      <% if @report.location_description.present? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("reports.show.location") %></p>
          <p class="mt-1 text-slate-800"><%= @report.location_description %></p>
        </div>
      <% end %>

      <% if @report.latitude.present? && @report.longitude.present? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-2"><%= t("reports.show.location_map") %></p>
          <div class="rounded-lg border border-slate-200 overflow-hidden" style="height: 200px;" id="show-map"
               data-lat="<%= @report.latitude %>" data-lng="<%= @report.longitude %>"></div>
          <p class="mt-1 text-xs text-slate-400"><%= @report.latitude %>, <%= @report.longitude %></p>
        </div>
        <script>
          document.addEventListener("turbo:load", function() {
            var el = document.getElementById("show-map");
            if (!el || typeof L === "undefined") return;
            if (el._leaflet_id && window._showReportMap) {
              window._showReportMap.remove();
              window._showReportMap = null;
            }
            var lat = parseFloat(el.dataset.lat), lng = parseFloat(el.dataset.lng);
            var map = L.map("show-map", { zoomControl: true, dragging: true, scrollWheelZoom: false }).setView([lat, lng], 16);
            window._showReportMap = map;
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>', maxZoom: 19
            }).addTo(map);
            L.marker([lat, lng]).addTo(map);
          });
          document.addEventListener("turbo:before-cache", function() {
            if (window._showReportMap) { window._showReportMap.remove(); window._showReportMap = null; }
          });
        </script>
      <% end %>

      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("reports.show.description") %></p>
        <p class="mt-1 text-slate-800 whitespace-pre-wrap"><%= @report.description %></p>
      </div>

      <% if @report.photos.attached? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-2">Fotos</p>
          <div class="flex gap-2 flex-wrap">
            <% @report.photos.each do |photo| %>
              <% blob = photo.is_a?(ActiveStorage::Blob) ? photo : photo.blob %>
              <%= link_to rails_storage_proxy_path(blob), target: "_blank", rel: "noopener", class: "block" do %>
                <%= image_tag rails_storage_proxy_path(blob), class: "rounded-lg object-cover h-24 w-24 max-w-none", alt: "Foto del reporte", loading: "lazy" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @report.resolved? && @report.resolution_note.present? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Nota de resolución</p>
          <p class="mt-1 text-slate-800 whitespace-pre-wrap"><%= @report.resolution_note %></p>
        </div>
      <% end %>

      <% if @report.resolved? && @report.resolution_photos.attached? %>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-2">Fotos de solución</p>
          <div class="flex gap-2 flex-wrap">
            <% @report.resolution_photos.each do |photo| %>
              <% blob = photo.is_a?(ActiveStorage::Blob) ? photo : photo.blob %>
              <%= link_to rails_storage_proxy_path(blob), target: "_blank", rel: "noopener", class: "block" do %>
                <%= image_tag rails_storage_proxy_path(blob), class: "rounded-lg object-cover h-24 w-24 max-w-none", alt: "Foto de solución", loading: "lazy" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% timeline = @report.timeline_items %>
      <% if timeline.any? %>
        <div class="mt-6 pt-6 border-t border-slate-200">
          <p class="text-sm font-medium text-slate-700 mb-3"><%= t("reports.show.history") %></p>
          <ul class="space-y-4">
            <% timeline.each do |item| %>
              <li class="flex gap-3 text-sm">
                <span class="shrink-0 w-2.5 h-2.5 mt-1.5 rounded-full
                  <%= case item[:type]
                      when :created then 'bg-slate-400'
                      when :read then 'bg-blue-500'
                      when :assigned then 'bg-violet-500'
                      when :resolved then 'bg-emerald-500'
                      when :rejected then 'bg-amber-500'
                      when :accepted, :auto_closed then 'bg-emerald-600'
                      else 'bg-slate-300'
                      end %>">
                </span>
                <div class="flex-1 min-w-0">
                  <span class="text-slate-500 text-xs"><%= l(item[:occurred_at], format: :short) %></span>
                  <div class="mt-0.5 text-slate-800">
                    <% case item[:type]
                       when :created %>
                      <%= t("reports.show.timeline.created") %>
                    <% when :read %>
                      <%= t("reports.show.timeline.read") %>
                    <% when :assigned %>
                      <% cycle = item[:cycle] %>
                      <% assignee_name = cycle ? cycle.assignee&.name : @report.assignee&.name %>
                      <%= t("reports.show.timeline.assigned", name: assignee_name || "—") %>
                      <% note = cycle&.assignment_note.presence || (!cycle && @report.assignment_note.present? ? @report.assignment_note : nil) %>
                      <% if note.present? %>
                        <p class="mt-1 text-xs font-medium text-slate-500"><%= t("reports.show.timeline.assignment_note_label") %></p>
                        <div class="mt-1 p-3 rounded-lg bg-slate-50 border border-slate-100 text-slate-700 whitespace-pre-wrap"><%= note %></div>
                      <% end %>
                    <% when :resolved %>
                      <% cycle = item[:cycle] %>
                      <% resolver_name = cycle ? (cycle.resolver || cycle.assignee)&.name : (@report.resolved_by || @report.assignee)&.name %>
                      <% n = item[:attempt] %>
                      <% if n && n > 1 %>
                        <%= t("reports.show.timeline.resolved_attempt", n: n) %> — <%= resolver_name || "—" %>
                      <% else %>
                        <%= t("reports.show.timeline.resolved", name: resolver_name || "—" ) %>
                      <% end %>
                      <% note = (cycle ? cycle.resolution_note : @report.resolution_note).to_s.strip %>
                      <% has_cycle_photos = cycle&.photos&.attached? %>
                      <% has_current_photos = item[:current] && @report.resolution_photos.attached? %>
                      <div class="mt-2 p-4 rounded-lg bg-emerald-50 border border-emerald-200">
                        <p class="text-xs font-semibold text-emerald-800 uppercase tracking-wide mb-2"><%= t("reports.show.timeline.resolution_note_label") %></p>
                        <% if note.present? %>
                          <p class="text-slate-800 whitespace-pre-wrap"><%= note %></p>
                        <% elsif has_cycle_photos || has_current_photos %>
                          <p class="text-slate-500 italic"><%= t("reports.show.timeline.photo_only") %></p>
                        <% else %>
                          <p class="text-slate-500 italic"><%= t("reports.show.timeline.no_details") %></p>
                        <% end %>
                        <% if has_cycle_photos %>
                          <div class="flex gap-2 mt-3 flex-wrap">
                            <% cycle.photos.each do |photo| %>
                              <% blob = photo.is_a?(ActiveStorage::Blob) ? photo : photo.blob %>
                              <%= link_to rails_storage_proxy_path(blob), target: "_blank", rel: "noopener", class: "block" do %>
                                <%= image_tag rails_storage_proxy_path(blob), class: "rounded h-20 w-20 object-cover border border-emerald-200", alt: "Foto", loading: "lazy" %>
                              <% end %>
                            <% end %>
                          </div>
                        <% end %>
                        <% if has_current_photos %>
                          <div class="flex gap-2 mt-3 flex-wrap">
                            <% @report.resolution_photos.each do |photo| %>
                              <% blob = photo.is_a?(ActiveStorage::Blob) ? photo : photo.blob %>
                              <%= link_to rails_storage_proxy_path(blob), target: "_blank", rel: "noopener", class: "block" do %>
                                <%= image_tag rails_storage_proxy_path(blob), class: "rounded h-20 w-20 object-cover border border-emerald-200", alt: "Foto", loading: "lazy" %>
                              <% end %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    <% when :rejected %>
                      <% n = item[:attempt] %>
                      <%= n && n > 1 ? t("reports.show.timeline.rejected_attempt", n: n) : t("reports.show.timeline.rejected") %>
                      <% if item[:cycle]&.reporter_rejection_note.present? %>
                        <p class="mt-1 text-xs font-medium text-slate-500"><%= t("reports.show.timeline.rejection_note_label") %></p>
                        <div class="mt-1 p-3 rounded-lg bg-amber-50 border border-amber-100 text-slate-700 whitespace-pre-wrap"><%= item[:cycle].reporter_rejection_note %></div>
                      <% end %>
                    <% when :accepted %>
                      <%= t("reports.show.timeline.accepted") %>
                    <% when :auto_closed %>
                      <%= t("reports.show.timeline.auto_closed") %>
                    <% end %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% reporter_sees_resolved = @report.resolved? && Current.user&.id == @report.reporter_id %>
      <% if reporter_sees_resolved && @report.reporter_accepted_at.present? %>
        <div class="mt-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200">
          <p class="text-sm font-medium text-emerald-800">Aceptaste esta resolución el <%= l(@report.reporter_accepted_at, format: :long) %></p>
        </div>
      <% elsif reporter_sees_resolved %>
        <div class="mt-6 space-y-4">
          <div class="p-4 rounded-lg bg-emerald-50 border border-emerald-200">
            <p class="text-sm font-medium text-emerald-800 mb-2">¿Estás conforme con la resolución?</p>
            <%= button_to "Aceptar resolución", accept_resolution_report_path(@report), method: :patch, class: "w-full py-3 px-4 rounded-lg bg-teal-600 text-white font-semibold hover:bg-teal-700 text-base cursor-pointer border-2 border-teal-700 shadow-md" %>
          </div>
          <% can_reject = @report.resolved_at && @report.resolved_at >= 72.hours.ago %>
          <% if can_reject %>
            <div class="p-4 rounded-lg bg-amber-50 border border-amber-200">
              <p class="text-sm font-medium text-amber-800 mb-2">¿No estás conforme?</p>
              <p class="text-sm text-slate-600 mb-3">Tienes 72 horas para dar réplica. Al rechazar, debes justificar tu motivo.</p>
              <%= form_with url: reject_resolution_report_path(@report), method: :patch, local: true, class: "space-y-4" do |f| %>
                <%= f.text_area :reporter_rejection_note, rows: 3, required: true, placeholder: "Justifica por qué no aceptas esta resolución...", class: "w-full rounded-lg border-slate-300" %>
                <div class="pt-2">
                  <%= f.submit "Rechazar resolución", class: "w-full py-3 px-4 rounded-lg bg-teal-600 text-white font-semibold hover:bg-teal-700 text-base cursor-pointer border-2 border-teal-700 shadow-md" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if Current.user&.system_admin? %>
      <div class="mt-6 p-4 rounded-lg bg-slate-50 border border-slate-300">
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-2">Forzar cambio de estado (Admin)</p>
        <%= form_with url: force_transition_report_path(@report), method: :patch, local: true, class: "flex items-center gap-3" do |f| %>
          <%= f.select :status,
              Report::STATUSES.map { |s| [t("status.#{s}", default: s.humanize), s] },
              { selected: @report.status },
              class: "rounded-lg border-slate-300 text-sm px-3 py-2" %>
          <%= f.submit "Forzar transición", class: "px-4 py-2 rounded-lg bg-teal-600 text-white text-sm font-medium hover:bg-teal-700 cursor-pointer border-2 border-teal-700" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
